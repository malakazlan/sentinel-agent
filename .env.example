# .env.example — Sentinel
# Copy this file to `.env` (which is gitignored) and fill in values.
# Never commit `.env` — secrets stay local or in GCP Secret Manager.

# ─────────────────────────────────────────────────────────────────────
# Google Cloud / Gemini
# ─────────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
# Use `global` for Gemini 3.x model family (ADR-010); `us-central1` is
# sufficient for Gemini 2.5 and older.
GOOGLE_CLOUD_LOCATION=global

# Toggle the ADK / google-genai client between Vertex AI (recommended for
# this project — GCP-native, judged signal) and AI Studio.
#   true  → use Vertex AI on GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION
#   false → use AI Studio with GOOGLE_API_KEY below
GOOGLE_GENAI_USE_VERTEXAI=true

# ── Auth: pick ONE path below ────────────────────────────────────────
#
# (1) Application Default Credentials — recommended for local dev.
#     Run `gcloud auth application-default login` once and leave the
#     two variables below blank.
#
# (2) Service-account key — recommended for CI and Cloud Run.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
#
# (3) AI Studio API key — only valid when GOOGLE_GENAI_USE_VERTEXAI=false.
# GOOGLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Phoenix (self-hosted — see ADR-003)
# ─────────────────────────────────────────────────────────────────────
# We run Phoenix locally for the entire dev cycle. NO Phoenix Cloud key
# here — Phoenix Cloud is geo-blocked and explicitly out of scope.
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_PROJECT_NAME=sentinel

# ─────────────────────────────────────────────────────────────────────
# Streamlit UI
# ─────────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ─────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR — use DEBUG during agent development,
# INFO once the system is stable.
LOG_LEVEL=INFO
