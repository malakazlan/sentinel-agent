{
  "openapi": "3.1.0",
  "info": {
    "title": "Sentinel API",
    "description": "HTTP + SSE wrapper around the Sentinel five-agent pipeline.",
    "version": "0.1.0"
  },
  "paths": {
    "/incidents": {
      "post": {
        "tags": [
          "incidents"
        ],
        "summary": "Create Incident",
        "description": "Start a new incident pipeline run for the given scenario.",
        "operationId": "create_incident_incidents_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIncidentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateIncidentResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/incidents/{incident_id}/stream": {
      "get": {
        "tags": [
          "incidents"
        ],
        "summary": "Stream Incident",
        "description": "Stream this incident's lifecycle events as SSE.\n\nEach `data:` line is one JSON-encoded `IncidentEvent`. The stream\ncloses when an `incident_completed` or `incident_failed` terminal\nevent is sent.",
        "operationId": "stream_incident_incidents__incident_id__stream_get",
        "parameters": [
          {
            "name": "incident_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Incident Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/incidents/{incident_id}": {
      "get": {
        "tags": [
          "incidents"
        ],
        "summary": "Get Incident",
        "description": "Return the final validated result for an incident.\n\nStatus codes:\n- 200 with the full result (succeeded or failed) when the pipeline finished\n- 202 with ``{status: \"running\"}`` when the pipeline is still in flight\n- 404 when the incident isn't in the registry",
        "operationId": "get_incident_incidents__incident_id__get",
        "parameters": [
          {
            "name": "incident_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Incident Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response Get Incident Incidents  Incident Id  Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Simple liveness probe \u2014 returns `{'status': 'ok'}`.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateIncidentRequest": {
        "properties": {
          "scenario_id": {
            "type": "string",
            "maxLength": 80,
            "minLength": 3,
            "title": "Scenario Id"
          }
        },
        "type": "object",
        "required": [
          "scenario_id"
        ],
        "title": "CreateIncidentRequest",
        "description": "Request body for POST /incidents \u2014 identifies which scenario to run."
      },
      "CreateIncidentResponse": {
        "properties": {
          "incident_id": {
            "type": "string",
            "title": "Incident Id"
          },
          "scenario_id": {
            "type": "string",
            "title": "Scenario Id"
          },
          "severity": {
            "type": "string",
            "title": "Severity"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "title": "Started At"
          }
        },
        "type": "object",
        "required": [
          "incident_id",
          "scenario_id",
          "severity",
          "title",
          "started_at"
        ],
        "title": "CreateIncidentResponse",
        "description": "Response body confirming an incident was accepted and scheduled."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}